# Server
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=info
DEVICE=cuda            # cuda | cpu | mps

# Auth (set to non-empty to require Authorization: Bearer <token>)
AUTH_TOKEN=

# Comma-separated allowed origins. Use http://localhost:3000 in dev.
CORS_ORIGINS=http://localhost:3000

# Upload + session limits
MAX_IMAGE_UPLOAD_MB=16
MAX_AUDIO_UPLOAD_MB=32
MAX_SESSIONS=16

# WebRTC ICE servers
STUN_URL=stun:stun.l.google.com:19302
# Set for NAT traversal in production. Use coturn or a managed TURN provider.
TURN_URL=
TURN_USERNAME=
TURN_CREDENTIAL=

# STT (faster-whisper)
STT_MODEL=large-v3-turbo
STT_COMPUTE_TYPE=float16
STT_LANGUAGE=auto
VAD_THRESHOLD=0.55
VAD_SILENCE_MS=450

# LLM
LLM_BACKEND=ollama     # ollama | openai
LLM_MODEL=llama3.1:8b
LLM_BASE_URL=http://localhost:11434
LLM_API_KEY=
LLM_SYSTEM_PROMPT="You are a friendly, concise video-call assistant. Speak naturally, like a person. Keep replies under 3 sentences unless asked for detail."
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=256
LLM_MAX_RETRIES=1
LLM_RETRY_BACKOFF_S=0.4

# Rate limiting (requests per minute per client IP)
RATE_LIMIT_OFFER_PER_MIN=30
RATE_LIMIT_UPLOAD_PER_MIN=10

# Graceful shutdown — bound how long we wait for sessions to drain
SHUTDOWN_DRAIN_S=15

# Set true when behind HTTPS — sends Strict-Transport-Security
ENABLE_HSTS=false

# TTS
TTS_BACKEND=piper      # piper | xtts
TTS_VOICE=en_US-amy-medium
TTS_SAMPLE_RATE=22050
XTTS_SPEAKER_WAV=

# Lip-sync avatar
LIPSYNC_BACKEND=musetalk      # musetalk | wav2lip
LIPSYNC_FPS=25
LIPSYNC_BATCH=4
AVATAR_IMAGE=media/personas/default.png

# Behavior
BARGE_IN=true
RESPONSE_DELAY_MS=120

# Virtual camera
ENABLE_VIRTUAL_CAMERA=false
VIRTUAL_CAMERA_DEVICE=/dev/video10
VIRTUAL_CAMERA_WIDTH=512
VIRTUAL_CAMERA_HEIGHT=512
